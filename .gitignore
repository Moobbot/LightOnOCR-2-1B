# ─────────────────────────────────────────────────────────────────────────────
# .gitignore — LightOnOCR-2-1B
#
# Model weights (*.safetensors, tokenizer.json...) được track bằng Git LFS
# thông qua .gitattributes — KHÔNG liệt kê ở đây.
# ─────────────────────────────────────────────────────────────────────────────

# Nếu bạn muốn tách file weights ra khỏi repo và tải khi lần đầu chạy,
# hãy bỏ comment dòng bên dưới để tránh commit nhầm file lớn.
# (Đồng thời set `MODEL_URL` để script tự tải khi cần.)
model.safetensors

# Output pipeline
outputs/

# HuggingFace evaluation cache
.eval_results/

# Python bytecode
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Build / dist
*.egg-info/
dist/
build/

# Conda / venv
.env
.venv/

# IDE
.vscode/
.idea/
*.code-workspace

# Temp / log
*.tmp
*.log
