# ── LightOnOCR-2-1B · Environment Configuration ──────────────────────────────

# ── Model & Device ───────────────────────────────────────────────────────────
# Đường dẫn tới model weights (để trống = dùng thư mục hiện tại)
# MODEL_PATH=/app/model

# Thiết bị tính toán:
#   auto    — tự động chọn GPU nếu có, ngược lại dùng CPU (mặc định)
#   cpu     — ép chạy CPU (phù hợp máy không có GPU / low-VRAM)
#   gpu     — ép chạy CUDA GPU (thoát lỗi nếu không có GPU)
LIGHTONOCR_DEVICE=auto

# Kiểu dữ liệu:
#   auto      — bfloat16 nếu GPU, float32 nếu CPU (mặc định)
#   bfloat16  — tiết kiệm VRAM ~50% trên GPU
#   float32   — an toàn nhất, dùng nhiều RAM hơn
# LIGHTONOCR_DTYPE=auto

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=7861

# Cho phép CORS từ tất cả nguồn gốc (*)
# Hoặc liệt kê cụ thể: http://localhost:8000,https://yourdomain.com
CORS_ALLOW_ORIGINS=*

# ── Logging ───────────────────────────────────────────────────────────────────
# Mức độ log: DEBUG | INFO | WARNING | ERROR (mặc định: INFO)
# LOG_LEVEL=INFO
